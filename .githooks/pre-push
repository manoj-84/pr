#!/bin/sh
# ============================================================
#  Plant Power Hub — pre-push hook
#  Blocks direct pushes to `main` or `develop`.
#  All changes must go through a Pull Request.
#
#  Install once per machine:
#    git config core.hooksPath .githooks
# ============================================================

PROTECTED_BRANCHES="main develop"
CURRENT_BRANCH=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

for branch in $PROTECTED_BRANCHES; do
  if [ "$CURRENT_BRANCH" = "$branch" ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════╗"
    echo "║  🚫  DIRECT PUSH BLOCKED — Plant Power Hub           ║"
    echo "╠══════════════════════════════════════════════════════╣"
    echo "║                                                      ║"
    echo "║  You cannot push directly to: $branch               "
    echo "║                                                      ║"
    echo "║  Please follow the team workflow:                    ║"
    echo "║    1. Create a feature branch from develop           ║"
    echo "║       git checkout develop                           ║"
    echo "║       git checkout -b feat/your-feature             ║"
    echo "║    2. Push your feature branch                       ║"
    echo "║       git push origin feat/your-feature             ║"
    echo "║    3. Open a Pull Request on GitHub                  ║"
    echo "║                                                      ║"
    echo "║  See CONTRIBUTING.md for the full workflow.          ║"
    echo "╚══════════════════════════════════════════════════════╝"
    echo ""
    exit 1
  fi
done

exit 0
