# ============================================================
#  Plant Power Hub — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  ⚠️  NEVER commit the actual .env file to git!
# ============================================================

# App
VITE_APP_NAME=Plant Power Hub
VITE_APP_ENV=development          # development | staging | production

# API (Backend / Data Sources)
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_KEY=your_api_key_here

# RS485 / Inverter Integration (if applicable)
VITE_INVERTER_POLL_INTERVAL_MS=60000

# Authentication (if applicable)
VITE_AUTH_DOMAIN=
VITE_AUTH_CLIENT_ID=

# Feature Flags
VITE_ENABLE_MOCK_DATA=true        # set to false to use real API
